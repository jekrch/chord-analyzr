# Base URL of the chord-analyzr Go API (api-go). Leave unset in dev — the
# Vite dev server proxies /api to http://localhost:8080 (see vite.config.ts),
# which avoids CORS since the browser sees a same-origin request. Set this
# for a prod build that talks to the API directly cross-origin; the API's
# CORS_ALLOWED_ORIGINS must then include this app's deployed origin.
# VITE_API_BASE_URL=http://localhost:8080

# Base URL of the main modal chord buildr app — used to generate deep links
VITE_BUILDR_URL=https://modal.chordbuildr.com
