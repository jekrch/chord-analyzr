{
 "openapi": "3.0.3",
 "info": {
  "title": "chord-analyzr API",
  "description": "API for chord-analyzr",
  "version": "0.0.1"
 },
 "servers": [
  {
   "url": "http://localhost:8080"
  }
 ],
 "paths": {
  "/api/modes": {
   "get": {
    "tags": [
     "mode-controller"
    ],
    "summary": "Get modes",
    "description": "Get all modes",
    "operationId": "getModes",
    "responses": {
     "200": {
      "description": "OK",
      "content": {
       "application/json": {
        "schema": {
         "type": "array",
         "items": {
          "$ref": "#/components/schemas/ModeDto"
         }
        }
       }
      }
     }
    }
   }
  },
  "/api/scales": {
   "get": {
    "tags": [
     "scale-controller"
    ],
    "summary": "Get scale notes",
    "description": "Get scale notes",
    "operationId": "getScaleNotes",
    "parameters": [
     {
      "name": "key",
      "in": "query",
      "required": true,
      "schema": {
       "type": "string"
      }
     },
     {
      "name": "mode",
      "in": "query",
      "required": true,
      "schema": {
       "type": "string"
      }
     }
    ],
    "responses": {
     "200": {
      "description": "OK",
      "content": {
       "application/json": {
        "schema": {
         "type": "array",
         "items": {
          "$ref": "#/components/schemas/ScaleNoteDto"
         }
        }
       }
      }
     }
    }
   }
  },
  "/api/chords": {
   "get": {
    "tags": [
     "chord-controller"
    ],
    "summary": "Get chords by mode and key name",
    "description": "Get chords by mode and key name",
    "operationId": "getModeKeyChords",
    "parameters": [
     {
      "name": "key",
      "in": "query",
      "required": true,
      "schema": {
       "type": "string"
      }
     },
     {
      "name": "mode",
      "in": "query",
      "required": true,
      "schema": {
       "type": "string"
      }
     }
    ],
    "responses": {
     "200": {
      "description": "OK",
      "content": {
       "application/json": {
        "schema": {
         "type": "array",
         "items": {
          "$ref": "#/components/schemas/ModeScaleChordDto"
         }
        }
       }
      }
     }
    }
   }
  },
  "/api/progressions": {
   "get": {
    "tags": [
     "progression-controller"
    ],
    "summary": "Generate a smooth chord progression",
    "description": "Generates the smoothest (minimal voice-leading) progression of the given length that starts on startChord and stays within the key/mode. rootWeight (>= 0) biases the search toward purposeful functional root motion; slashWeight (>= 0) enables inversions / slash chords chosen to smooth the bass line. Both default to 0 (off). randomness (0-1) adds variety: each call picks a different near-smoothest progression instead of always the same one; reported costs stay the true voice-leading motion. extraNotes lists non-scale notes chords may borrow (e.g. extraNotes=F%23,Bb) for chromatic color -- at least one chord will use one when possible. maxNotes (> 0) softly caps chord size for leaner chords; oversized chords still appear when nothing leaner comes close. pinned lists further chords the progression must contain, each as 'Chord' (placed wherever it fits most smoothly) or 'Chord@step' (fixed at that 1-based step, e.g. pinned=Am7,G7@3); the search fills the remaining steps around them. Pinned chords and the start chord may use notes outside the key/mode. required lists notes the progression must voice, each as 'Note@step' (1-based step, e.g. required=A@3,Eb@4): the chord at that step will contain the note -- pass a melody note per step to reharmonize under it. Several entries may name one step. A required note outside the key/mode is honored, but only at the steps that require it; a requirement on step 1 or on a pinned step gives way to that chord. resultCount (1-10, default 1) returns that many alternative progressions, best first, each a distinct chord sequence grouped by progressionId in the response rows. colorWeight (> 0) admits chords rooted outside the scale -- bVI, bVII, the Neapolitan, chromatic mediants (modal-interchange color); higher = bolder, try 1-3, and the length cap rises from 8 to 12. colorDevices restricts that color to specific devices: borrowed, mediant, secondary_dominant, tritone_sub, chromatic (e.g. colorDevices=mediant for chromatic-mediant chains); empty allows all.",
    "operationId": "getSmoothProgression",
    "parameters": [
     {
      "name": "key",
      "in": "query",
      "required": true,
      "schema": {
       "type": "string"
      }
     },
     {
      "name": "mode",
      "in": "query",
      "required": true,
      "schema": {
       "type": "string"
      }
     },
     {
      "name": "startChord",
      "in": "query",
      "required": true,
      "schema": {
       "type": "string"
      }
     },
     {
      "name": "length",
      "in": "query",
      "required": false,
      "schema": {
       "type": "integer",
       "format": "int32",
       "default": 4
      }
     },
     {
      "name": "rootWeight",
      "in": "query",
      "required": false,
      "schema": {
       "type": "number",
       "format": "double",
       "default": 0
      }
     },
     {
      "name": "slashWeight",
      "in": "query",
      "required": false,
      "schema": {
       "type": "number",
       "format": "double",
       "default": 0
      }
     },
     {
      "name": "randomness",
      "in": "query",
      "required": false,
      "schema": {
       "type": "number",
       "format": "double",
       "default": 0
      }
     },
     {
      "name": "extraNotes",
      "in": "query",
      "required": false,
      "schema": {
       "type": "array",
       "items": {
        "type": "string"
       }
      }
     },
     {
      "name": "maxNotes",
      "in": "query",
      "required": false,
      "schema": {
       "type": "integer",
       "format": "int32",
       "default": 0
      }
     },
     {
      "name": "pinned",
      "in": "query",
      "required": false,
      "schema": {
       "type": "array",
       "items": {
        "type": "string"
       }
      }
     },
     {
      "name": "required",
      "in": "query",
      "required": false,
      "schema": {
       "type": "array",
       "items": {
        "type": "string"
       }
      }
     },
     {
      "name": "resultCount",
      "in": "query",
      "required": false,
      "schema": {
       "type": "integer",
       "format": "int32",
       "default": 1
      }
     },
     {
      "name": "colorWeight",
      "in": "query",
      "required": false,
      "schema": {
       "type": "number",
       "format": "double",
       "default": 0
      }
     },
     {
      "name": "colorDevices",
      "in": "query",
      "required": false,
      "schema": {
       "type": "array",
       "items": {
        "type": "string"
       }
      }
     }
    ],
    "responses": {
     "200": {
      "description": "OK",
      "content": {
       "application/json": {
        "schema": {
         "type": "array",
         "items": {
          "$ref": "#/components/schemas/ProgressionStep"
         }
        }
       }
      }
     }
    }
   }
  }
 },
 "components": {
  "schemas": {
   "ModeDto": {
    "type": "object",
    "properties": {
     "id": {
      "type": "integer",
      "format": "int64"
     },
     "name": {
      "type": "string"
     }
    }
   },
   "ScaleNoteDto": {
    "type": "object",
    "properties": {
     "seqNote": {
      "type": "integer",
      "format": "int64"
     },
     "noteName": {
      "type": "string"
     }
    }
   },
   "ModeScaleChordDto": {
    "type": "object",
    "properties": {
     "modeId": {
      "type": "integer",
      "format": "int64"
     },
     "chordTypeId": {
      "type": "integer",
      "format": "int64"
     },
     "chordNote": {
      "type": "integer",
      "format": "int32"
     },
     "keyNote": {
      "type": "integer",
      "format": "int32"
     },
     "mode": {
      "type": "string"
     },
     "keyName": {
      "type": "string"
     },
     "chordNoteName": {
      "type": "string"
     },
     "chordName": {
      "type": "string"
     },
     "modeNotes": {
      "type": "array",
      "items": {
       "type": "integer",
       "format": "int32"
      }
     },
     "chordNotes": {
      "type": "string"
     },
     "chordNoteNames": {
      "type": "string"
     },
     "modeChordNoteDiff": {
      "type": "array",
      "items": {
       "type": "integer",
       "format": "int32"
      }
     },
     "modeChordNoteDiffCount": {
      "type": "integer",
      "format": "int32"
     }
    }
   },
   "ProgressionStep": {
    "type": "object",
    "properties": {
     "progressionId": {
      "type": "integer",
      "format": "int32"
     },
     "step": {
      "type": "integer",
      "format": "int32"
     },
     "chord": {
      "type": "string"
     },
     "vlFromPrev": {
      "type": "integer",
      "format": "int32"
     },
     "totalCost": {
      "type": "integer",
      "format": "int32"
     }
    }
   }
  }
 }
}
